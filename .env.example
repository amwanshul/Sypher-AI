# Provider keys can also be saved in Command Center > API Keys.
GEMINI_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=
HUGGINGFACE_API_KEY=

# Local Google OAuth backend used by the Initialize Link.
VITE_BACKEND_KEY=http://localhost:3000
SYPHER_AUTH_PORT=3000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/users/google/callback
# Gmail tools use this local callback. Add the exact URI in Google Cloud Console.
GOOGLE_GMAIL_OAUTH_REDIRECT_URI=http://localhost:3001/oauth2callback
SYPHER_AUTH_REDIRECT_URI=sypher://auth/callback
